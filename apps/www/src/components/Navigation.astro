---
interface Props {
  logoSrc: string;
}

const { logoSrc } = Astro.props;
---

<div id="site-navigation">
  <nav class="flex justify-between items-center max-w-6xl mx-auto">
    <div class="text-xl font-bold flex gap-4 items-center flex-grow">
      <img src={logoSrc} height="128" width="128" alt="Logo" class="h-[2em] w-auto object-contain" />
      Tiger Taylor
    </div>

    <ul class="hidden sm:flex space-x-6">
      <li>
        <a href="#about" class="hover:underline" data-nav-target="about">About</a>
      </li>
      <li>
        <a href="#projects" class="hover:underline" data-nav-target="projects">Projects</a>
      </li>
      <li>
        <a href="#contact" class="hover:underline" data-nav-target="contact">Contact</a>
      </li>
    </ul>

    <div class="sm:hidden">
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Toggle menu"
        class="p-2 focus:outline-none"
        aria-expanded="false"
      >
        <span id="mobile-menu-icon-open" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </span>
        <span id="mobile-menu-icon-close" class="hidden" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="sm:hidden border-t border-gray-200 overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0 border-t-0"
  >
    <ul class="flex flex-col space-y-3 py-2">
      <li class="menu-item-enter delay-75">
        <a href="#about" class="block px-2 py-1 hover:bg-gray-100 rounded" data-nav-target="about">About</a>
      </li>
      <li class="menu-item-enter delay-150">
        <a href="#projects" class="block px-2 py-1 hover:bg-gray-100 rounded" data-nav-target="projects">Projects</a>
      </li>
      <li class="menu-item-enter delay-300">
        <a href="#contact" class="block px-2 py-1 hover:bg-gray-100 rounded" data-nav-target="contact">Contact</a>
      </li>
    </ul>
  </div>
</div>

<script is:inline>
  const navRoot = document.getElementById("site-navigation");

  if (navRoot) {
    const toggleButton = navRoot.querySelector("#mobile-menu-toggle");
    const mobileMenu = navRoot.querySelector("#mobile-menu");
    const openIcon = navRoot.querySelector("#mobile-menu-icon-open");
    const closeIcon = navRoot.querySelector("#mobile-menu-icon-close");
    let isOpen = false;

    const applyMenuState = () => {
      if (mobileMenu instanceof HTMLElement) {
        mobileMenu.classList.toggle("max-h-56", isOpen);
        mobileMenu.classList.toggle("mt-4", isOpen);
        mobileMenu.classList.toggle("opacity-100", isOpen);
        mobileMenu.classList.toggle("slide-down", isOpen);
        mobileMenu.classList.toggle("max-h-0", !isOpen);
        mobileMenu.classList.toggle("opacity-0", !isOpen);
        mobileMenu.classList.toggle("border-t-0", !isOpen);
      }

      if (openIcon instanceof HTMLElement && closeIcon instanceof HTMLElement) {
        openIcon.classList.toggle("hidden", isOpen);
        closeIcon.classList.toggle("hidden", !isOpen);
      }

      if (toggleButton instanceof HTMLElement) {
        toggleButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }
    };

    if (toggleButton instanceof HTMLElement) {
      toggleButton.addEventListener("click", () => {
        isOpen = !isOpen;
        applyMenuState();
      });
    }

    const links = navRoot.querySelectorAll("a[data-nav-target]");
    links.forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      link.addEventListener("click", () => {
        if (isOpen) {
          isOpen = false;
          applyMenuState();
        }
      });
    });
  }
</script>
