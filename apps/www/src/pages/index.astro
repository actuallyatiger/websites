---
import Layout from "../layouts/Layout.astro";
import CourseHighlights from "../components/CourseHighlights.astro";
import Item from "../components/Item.astro";
import Card from "../components/Card.astro";
import Icon from "../components/Icon";
import { projects } from "../data/projects";

const languageSkills = ["Python", "JavaScript", "TypeScript", "C/C++", "Rust", "Scala", "Haskell"];
const toolsSkills = ["Bash", "Git", "Docker", "Flask", "FastAPI", "Next.js", "Svelte", "PostgreSQL", "Google Cloud"];
---

<Layout>
  <main class="flex-grow">
    <section class="py-10 md:py-15 px-6 flex justify-center items-center">
      <div
        class="bg-gradient-to-br from-blue-500 to-blue-400 text-white text-center py-10 px-12 rounded-xl shadow-lg max-w-2xl"
      >
        <h1 class="text-4xl font-extrabold mb-4">Hi, I'm Tiger</h1>
        <p class="text-lg">
          I'm an Undergraduate Student at the University of Oxford
          <br />
          Studying Computer Science
        </p>
      </div>
    </section>

    <section id="about" class="py-10 md:py-15 px-6 bg-blue-50">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold mb-2">About Me</h2>
          <div class="h-1 w-20 bg-blue-500 mx-auto rounded-full"></div>
        </div>
        <div class="bg-white p-8 rounded-xl shadow-md">
          <p class="text-gray-700 leading-relaxed mb-6">
            I'm a Computer Science undergraduate at the University of Oxford with a passion for low-level systems,
            full-stack development, and networks. I've also taken a keen interest in developer tooling.
          </p>

          <CourseHighlights />

          <div>
            <h3 class="text-xl font-bold mb-4 text-blue-800 pb-2 border-b border-blue-100">Technical Skills</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-blue-50 p-5 rounded-lg">
                <h4 class="font-semibold text-gray-900 mb-3">Languages</h4>
                <div class="flex flex-wrap gap-2">
                  {languageSkills.map((skill) => <Item name={skill} />)}
                </div>
              </div>

              <div class="bg-blue-50 p-5 rounded-lg">
                <h4 class="font-semibold text-gray-900 mb-3">Tools &amp; Frameworks</h4>
                <div class="flex flex-wrap gap-2">
                  {toolsSkills.map((skill) => <Item name={skill} />)}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="py-10 md:py-15 px-6 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold mb-2">Projects</h2>
          <div class="h-1 w-20 bg-blue-500 mx-auto rounded-full"></div>
        </div>

        <div class="flex flex-wrap justify-center gap-8">
          {projects.map((project) => <Card {...project} />)}
        </div>
      </div>
    </section>

    <section id="contact" class="py-10 md:py-15 px-6 bg-gradient-to-b from-blue-50 to-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold mb-2">Contact Me</h2>
          <div class="h-1 w-20 bg-blue-500 mx-auto rounded-full"></div>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 md:p-10 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-40 h-40 bg-blue-100 rounded-full -mr-16 -mt-16"></div>
          <div class="absolute bottom-0 left-0 w-24 h-24 bg-blue-100 rounded-full -ml-10 -mb-10"></div>

          <div class="relative">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              <div class="text-center p-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
                  <Icon name="envelope" className="h-5 w-5 text-blue-600" />
                </div>
                <h3 class="font-semibold text-gray-800">Email</h3>
                <a
                  href="mailto:tiger@tigertaylor.xyz"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 text-sm"
                >
                  tiger@tigertaylor.xyz
                </a>
              </div>

              <div class="text-center p-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
                  <Icon name="phone" className="h-5 w-5 text-blue-600" />
                </div>
                <h3 class="font-semibold text-gray-800">Phone</h3>
                <a href="tel:+447496588340" target="_blank" rel="noopener noreferrer" class="text-blue-600 text-sm">
                  +44 7496 588340
                </a>
              </div>

              <div class="text-center p-4">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
                  <Icon name="linkedin" className="h-5 w-5 text-blue-600" />
                </div>
                <h3 class="font-semibold text-gray-800">LinkedIn</h3>
                <a
                  href="https://linkedin.com/in/tiger-taylor"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 text-sm"
                >
                  linkedin.com/in/tiger-taylor
                </a>
              </div>
            </div>

            <div class="text-center">
              <a
                href="https://links.tigertaylor.xyz"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-blue-600 text-white hover:bg-blue-700 px-8 py-3 font-medium inline-block rounded-lg shadow-md transition-colors duration-300"
              >
                View All Links
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
