---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Tiger Taylor", description = "Tiger Taylor's personal website" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-gradient-to-br from-[#3269FF] to-[#6A4C93] flex flex-col">
    <slot />
  </body>
</html>
